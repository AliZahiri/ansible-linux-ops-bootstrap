groups:
  - name: node-exporter-baseline
    rules:
      - alert: HostDiskSpaceLow
        expr: |
          node_filesystem_avail_bytes{fstype!~"tmpfs|overlay|squashfs"} / node_filesystem_size_bytes{fstype!~"tmpfs|overlay|squashfs"} < 0.15
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: Host disk space is below baseline threshold
      - alert: HostMemoryPressure
        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.10
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: Host memory pressure is above baseline threshold
      - alert: HostFilesystemReadOnly
        expr: node_filesystem_readonly{fstype!~"tmpfs|overlay|squashfs"} == 1
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: Host filesystem is mounted read-only
